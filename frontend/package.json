{
    "name": "pph-frontend",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "jest",
        "typecheck": "tsc --noEmit",
        "lint": "ng lint",
        "generate:api": "openapi-generator-cli generate -c openapi-generator.json",
        "generate:api:ci": "openapi-generator-cli generate -c openapi-generator.json --skip-validate-spec",
        "e2e": "playwright test"
    },
    "dependencies": {
        "@angular/animations": "^19.0.0",
        "@angular/common": "^19.0.0",
        "@angular/compiler": "^19.0.0",
        "@angular/core": "^19.0.0",
        "@angular/forms": "^19.0.0",
        "@angular/platform-browser": "^19.0.0",
        "@angular/platform-browser-dynamic": "^19.0.0",
        "@angular/router": "^19.0.0",
        "@sentry/angular": "^8.0.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.6.0",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular-builders/jest": "^19.0.0",
        "@angular-devkit/build-angular": "^19.0.0",
        "@angular/cli": "^19.0.0",
        "@angular/compiler-cli": "^19.0.0",
        "@openapitools/openapi-generator-cli": "^2.13.0",
        "@playwright/test": "^1.44.0",
        "@testing-library/angular": "^17.0.0",
        "@testing-library/user-event": "^14.5.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-preset-angular": "^14.1.0",
        "ts-jest": "^29.1.0",
        "typescript": "~5.5.0"
    }
}